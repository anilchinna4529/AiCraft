# ======================================
# AICraft — Environment variable template
# Copy to `.env` and fill in the real values.
# DO NOT commit `.env` to git.
# ======================================

# --- Core ---
NODE_ENV=production
PORT=3000
SITE_URL=https://your-app.onrender.com

# Optional: extra CORS origins, comma-separated
ALLOWED_ORIGINS=https://aicraft.co,https://www.aicraft.co

# --- Supabase ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# --- Email (Resend) ---
# Leave blank to disable email sending (the app will skip gracefully).
RESEND_API_KEY=
FROM_EMAIL=welcome@aicraft.co

# --- Stripe (Phase 2) ---
# Leave blank. Checkout endpoint returns 501 until this is set.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Salesforce Developer Toolkit ---
# Create a Connected App in your Salesforce org (App Manager → New Connected App)
# with OAuth enabled, PKCE "Require" allowed, and the callback URL set to:
#   ${SITE_URL}/api/salesforce/auth/callback
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_SCOPES=api refresh_token offline_access id
SF_API_VERSION=v62.0
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SF_ENCRYPTION_KEY=
