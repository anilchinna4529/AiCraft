bashCopy# ============================================
# STEP 1: Create Project Folder
# ============================================
mkdir aicraft
cd aicraft

# ============================================
# STEP 2: Initialize Project
# ============================================
npm init -y

# ============================================
# STEP 3: Install All Dependencies
# ============================================
npm install express cors dotenv @supabase/supabase-js

# ============================================
# STEP 4: Create All Files
# ============================================
touch server.js supabaseClient.js worker.js .env
mkdir public
touch public/index.html public/style.css

# ============================================
# STEP 5: Configure .env
# ============================================
# Open .env and fill in your credentials:
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=your-service-role-key-here
# PORT=3000

# ============================================
# STEP 6: Setup Supabase Database
# ============================================
# 1. Go to https://supabase.com
# 2. Create new project "aicraft"
# 3. Open SQL Editor
# 4. Paste and run the SQL schema above
# 5. Copy your Project URL + service_role key
# 6. Paste into .env file

# ============================================
# STEP 7: Run the Backend Server
# ============================================
npm start
# OR for development with auto-reload:
npm run dev

# ============================================
# STEP 8: Run the Background Worker
# (Open a NEW terminal window)
# ============================================
npm run worker

