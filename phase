    <script>
      const API_BASE = "";

      // ================================
      // NAVBAR SCROLL EFFECT
      // ================================
      window.addEventListener("scroll", () => {
        const navbar = document.getElementById("navbar");
        if (window.scrollY > 50) {
          navbar.classList.add("scrolled");
        } else {
          navbar.classList.remove("scrolled");
        }
      });

      // ================================
      // MOBILE HAMBURGER MENU
      // ================================
      document.getElementById("hamburger").addEventListener("click", () => {
        const navLinks = document.getElementById("navLinks");
        navLinks.classList.toggle("mobile-open");
      });

      // ================================
      // SMOOTH SCROLL
      // ================================
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener("click", function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute("href"));
          if (target) {
            target.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        });
      });

      // ================================
      // LOAD PLATFORM STATS
      // ================================
      async function loadStats() {
        try {
          const response = await fetch(`${API_BASE}/api/stats`);
          const data = await response.json();

          if (data.success) {
            document.getElementById("statTools").textContent =
              data.stats.total_tools + "+";
            document.getElementById("statUsers").textContent =
              data.stats.total_users + "+";
          }
        } catch (error) {
          console.error("Failed to load stats:", error);
          document.getElementById("statTools").textContent = "50+";
          document.getElementById("statUsers").textContent = "1K+";
        }
      }

      // ================================
      // LOAD SECTORS
      // ================================
      async function loadSectors() {
        const grid = document.getElementById("sectorsGrid");
        try {
          const response = await fetch(`${API_BASE}/api/sectors`);
          const data = await response.json();

          if (data.success && data.sectors.length > 0) {
            grid.innerHTML = data.sectors
              .map(
                (sector) => `
              <div class="sector-card">
                <div class="sector-icon">${sector.icon}</div>
                <h3>${sector.name}</h3>
                <p>${sector.description}</p>
                <a href="#tools" class="sector-link">Explore Tools →</a>
              </div>
            `
              )
              .join("");
          } else {
            grid.innerHTML =
              '<p class="no-data">No sectors available yet.</p>';
          }
        } catch (error) {
          console.error("Failed to load sectors:", error);
          grid.innerHTML =
            '<p class="error-msg">⚠️ Failed to load sectors. Please refresh.</p>';
        }
      }

      // ================================
      // LOAD AI TOOLS
      // ================================
      async function loadTools(sector = "all") {
        const grid = document.getElementById("toolsGrid");

        grid.innerHTML = `
          <div class="loading-state">
            <div class="spinner"></div>
            <p>Fetching AI Tools...</p>
          </div>`;

        try {
          let url = `${API_BASE}/api/tools`;
          if (sector !== "all") url += `?sector=${sector}`;

          const response = await fetch(url);
          const data = await response.json();

          if (data.success && data.tools.length > 0) {
            grid.innerHTML = data.tools
              .map(
                (tool) => `
              <div class="tool-card" data-sector="${tool.sector || "General"}">
                <div class="tool-card-image">
                  ${
                    tool.image_url
                      ? `<img src="${tool.image_url}" alt="${tool.name}" onerror="this.style.display='none'" />`
                      : `<div class="tool-image-placeholder">🤖</div>`
                  }
                  <div class="tool-sector-badge">${tool.sector || "General"}</div>
                </div>
                <div class="tool-card-body">
                  <div class="tool-card-header">
                    <h3 class="tool-name">${tool.name}</h3>
                    <span class="tool-price ${tool.price === "Free" ? "price-free" : "price-paid"}">
                      ${tool.price || "Free"}
                    </span>
                  </div>
                  <span class="tool-category">${tool.category}</span>
                  <p class="tool-description">${tool.description}</p>
                  <div class="tool-card-footer">
                    ${
                      tool.tool_link
                        ? `<a href="${tool.tool_link}" target="_blank" class="btn-tool-primary">
                          <i class="fas fa-external-link-alt"></i> Try Tool
                        </a>`
                        : `<button class="btn-tool-primary" disabled>
                          <i class="fas fa-lock"></i> Coming Soon
                        </button>`
                    }
                    <button class="btn-tool-secondary" onclick="logAction('view', '${tool.id}')">
                      <i class="fas fa-info-circle"></i> Details
                    </button>
                  </div>
                </div>
              </div>
            `
              )
              .join("");
          } else {
            grid.innerHTML = `
              <div class="empty-state">
                <div class="empty-icon">🤖</div>
                <h3>No AI Tools Yet</h3>
                <p>Be the first to submit an AI tool to our marketplace!</p>
                <a href="#addtool" class="btn-hero-primary">Submit a Tool</a>
              </div>`;
          }
        } catch (error) {
          console.error("Failed to load tools:", error);
          grid.innerHTML = `
            <div class="error-state">
              <div class="error-icon">⚠️</div>
              <h3>Connection Error</h3>
              <p>Make sure the backend server is running on port 3000.</p>
              <button class="btn-hero-primary" onclick="loadTools()">Retry</button>
            </div>`;
        }
      }

      // ================================
      // FILTER BUTTONS
      // ================================
      document.querySelectorAll(".filter-btn").forEach((btn) => {
        btn.addEventListener("click", function () {
          document
            .querySelectorAll(".filter-btn")
            .forEach((b) => b.classList.remove("active"));
          this.classList.add("active");
          loadTools(this.dataset.filter);
        });
      });

      // ================================
      // LOG USER ACTION
      // ================================
      async function logAction(actionType, toolId) {
        try {
          await fetch(`${API_BASE}/api/actions`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              action_type: actionType,
              tool_id: toolId,
              metadata: { timestamp: new Date().toISOString() },
            }),
          });
        } catch (error) {
          console.error("Failed to log action:", error);
        }
      }

      // ================================
      // SUBMIT NEW TOOL FORM
      // ================================
      document
        .getElementById("toolForm")
        .addEventListener("submit", async function (e) {
          e.preventDefault();

          const submitBtn = document.getElementById("submitBtn");
          const formMessage = document.getElementById("formMessage");

          submitBtn.innerHTML =
            '<i class="fas fa-spinner fa-spin"></i> Submitting...';
          submitBtn.disabled = true;

          const toolData = {
            name: document.getElementById("toolName").value,
            description: document.getElementById("toolDescription").value,
            category: document.getElementById("toolCategory").value,
            sector: document.getElementById("toolSector").value,
            price: document.getElementById("toolPrice").value || "Free",
            tool_link: document.getElementById("toolLink").value || null,
            image_url: document.getElementById("toolImage").value || null,
          };

          try {
            const response = await fetch(`${API_BASE}/api/tools`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(toolData),
            });

            const result = await response.json();

            formMessage.classList.remove("hidden");

            if (result.success) {
              formMessage.className = "form-message success";
              formMessage.innerHTML =
                "✅ Tool submitted successfully! It will appear in the marketplace shortly.";
              this.reset();
              setTimeout(() => loadTools(), 1000);
            } else {
              formMessage.className = "form-message error";
              formMessage.innerHTML = `❌ Error: ${result.error}`;
            }
          } catch (error) {
            formMessage.classList.remove("hidden");
            formMessage.className = "form-message error";
            formMessage.innerHTML =
              "❌ Connection failed. Make sure backend is running.";
          }

          submitBtn.innerHTML =
            '<i class="fas fa-plus-circle"></i> Submit AI Tool';
          submitBtn.disabled = false;

          setTimeout(() => {
            formMessage.classList.add("hidden");
          }, 5000);
        });

      // ================================
      // INITIALIZE PAGE
      // ================================
      document.addEventListener("DOMContentLoaded", () => {
        loadStats();
        loadSectors();
        loadTools();
      });
    </script>
  </body>
</html>

